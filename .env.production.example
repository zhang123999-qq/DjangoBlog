# Django 生产环境配置示例
# 使用方法：复制为 .env 后按实际环境填写

# =============================================================================
# 基础配置
# =============================================================================
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# 网站信息
# =============================================================================
SITE_NAME=Django Blog
SITE_TITLE=Django 综合网站

# =============================================================================
# 数据库配置 - MySQL
# =============================================================================
DB_ENGINE=django.db.backends.mysql
DB_NAME=djangoblog
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306

# =============================================================================
# Redis 配置
# =============================================================================
USE_REDIS=True
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # 如有密码请取消注释

# =============================================================================
# 缓存配置
# =============================================================================
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=redis://localhost:6379/1

# =============================================================================
# Session 配置
# =============================================================================
SESSION_ENGINE=django.contrib.sessions.backends.cache
SESSION_CACHE_ALIAS=default

# =============================================================================
# Celery 配置
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# =============================================================================
# 邮件配置（需要时填写）
# =============================================================================
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_email@example.com
# EMAIL_HOST_PASSWORD=your_password

# =============================================================================
# 百度内容审核 API（需要时填写）
# =============================================================================
# BAIDU_APP_ID=
# BAIDU_API_KEY=
# BAIDU_SECRET_KEY=

# =============================================================================
# API 配置
# =============================================================================
API_PAGE_SIZE=20
API_ANON_RATE=100/hour
API_USER_RATE=1000/hour
API_UPLOAD_RATE=30/hour
API_READ_RATE=1200/hour

# Moderation API 保护阈值
MODERATION_API_RATE_LIMIT_PER_MIN=120
MODERATION_API_MAX_CONCURRENCY=20
# Moderation UI 告警阈值
MODERATION_UI_ALERT_RATE_LIMITED=5
MODERATION_UI_ALERT_CONCURRENCY_LIMITED=3
MODERATION_UI_ALERT_FAIL_RATE=0.2

# =============================================================================
# 上传安全扫描（ClamAV，可选）
# =============================================================================
UPLOAD_CLAMAV_ENABLED=False
UPLOAD_CLAMAV_HOST=127.0.0.1
UPLOAD_CLAMAV_PORT=3310
UPLOAD_CLAMAV_TIMEOUT=5
UPLOAD_CLAMAV_FAIL_CLOSED=False
UPLOAD_ASYNC_PIPELINE_ENABLED=False
UPLOAD_STATUS_TTL=86400

# =============================================================================
# 安全配置（P0：生产必开）
# =============================================================================
# ⚠️ 警告：以下配置仅在 HTTPS 环境下开启！
# 纯 HTTP 部署时必须全部设为 False，否则会导致：
# - 全站无限重定向（SECURE_SSL_REDIRECT）
# - 登录/CSRF 完全失效（SESSION_COOKIE_SECURE/CSRF_COOKIE_SECURE）
# 
# 正确做法：
# 1. 先确认 Nginx/Apache 已配置 HTTPS
# 2. 设置 USE_X_FORWARDED_PROTO=True（让 Django 识别反向代理的 HTTPS）
# 3. 再开启以下安全配置
# =============================================================================

# 是否使用 HTTPS（反向代理场景设为 True）
USE_X_FORWARDED_PROTO=False

# SSL 重定向（仅 HTTPS 部署时开启）
SECURE_SSL_REDIRECT=False

# 安全 Cookie（仅 HTTPS 部署时开启）
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# HSTS（仅 HTTPS 部署时开启，强制浏览器记住 HTTPS）
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# 通用安全头（HTTP/HTTPS 都可开启）
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_REFERRER_POLICY=same-origin
