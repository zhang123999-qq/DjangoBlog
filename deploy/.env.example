# =============================================================================
# DjangoBlog 生产环境配置模板
# 使用方法: copy .env.example .env, 然后修改敏感值
# =============================================================================

# --- 基础 ---
DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=False
SECRET_KEY=<请使用 python -c "import secrets; print(secrets.token_urlsafe(64))" 生成>
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# --- 站点信息 ---
SITE_NAME=Django Blog
SITE_TITLE=Django Blog - 博客论坛系统
TIME_ZONE=Asia/Shanghai
LANGUAGE_CODE=zh-hans

# --- 数据库 ---
DB_ENGINE=django.db.backends.mysql
DB_NAME=djangoblog
DB_USER=djangouser
DB_PASSWORD=<数据库密码>
DB_HOST=db
DB_PORT=3306

# --- Redis ---
USE_REDIS=True
REDIS_URL=redis://redis:6379/1

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- 百度内容审核 ---
BAIDU_APP_ID=<百度AppID>
BAIDU_API_KEY=<百度APIKey>
BAIDU_SECRET_KEY=<百度SecretKey>
MODERATION_MODE=hybrid
MODERATION_AI_THRESHOLD=0.8
MODERATION_API_RATE_LIMIT_PER_MIN=120
MODERATION_API_MAX_CONCURRENCY=20
MODERATION_UI_ALERT_RATE_LIMITED=5
MODERATION_UI_ALERT_CONCURRENCY_LIMITED=3
MODERATION_UI_ALERT_FAIL_RATE=0.2

# --- HTTPS/安全 (有SSL后改为True) ---
USE_X_FORWARDED_PROTO=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- 邮件 ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=<邮箱密码>
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# --- 监控 (可选) ---
SENTRY_DSN=https://xxx@sentry.io/xxx
PROMETHEUS_ENABLED=False

# --- API ---
API_PAGE_SIZE=20
API_ANON_RATE=100/hour
API_USER_RATE=1000/hour
API_UPLOAD_RATE=30/hour
API_READ_RATE=1200/hour

# --- 上传安全 ---
UPLOAD_CLAMAV_ENABLED=False
UPLOAD_CLAMAV_HOST=127.0.0.1
UPLOAD_CLAMAV_PORT=3310
UPLOAD_CLAMAV_TIMEOUT=5
UPLOAD_CLAMAV_FAIL_CLOSED=False
UPLOAD_ASYNC_PIPELINE_ENABLED=False
UPLOAD_STATUS_TTL=86400

# --- 安装向导 (生产应关闭) ---
ENABLE_INSTALLER=False
