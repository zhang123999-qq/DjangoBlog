# Django 配置示例
# 复制此文件为 .env 并修改配置

# 安全配置
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# 站点信息
SITE_NAME=Django Blog
SITE_TITLE=Django Blog - 博客论坛系统

# MySQL 数据库配置
DB_ENGINE=django.db.backends.mysql
DB_NAME=djangoblog
DB_USER=djangouser
DB_PASSWORD=your-db-password
DB_HOST=db
DB_PORT=3306

# Redis 缓存配置
USE_REDIS=True
REDIS_URL=redis://redis:6379/1

# Celery 配置
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# 百度内容审核 API（可选）
BAIDU_APP_ID=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# 审核模式: auto(自动) / manual(手动) / hybrid(混合)
MODERATION_MODE=hybrid
MODERATION_AI_THRESHOLD=0.8

# CSRF信任来源
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://yourdomain.com

# API 配置
API_PAGE_SIZE=20
API_ANON_RATE=100/hour
API_USER_RATE=1000/hour
API_UPLOAD_RATE=30/hour

# 上传安全扫描（ClamAV，可选）
UPLOAD_CLAMAV_ENABLED=False
UPLOAD_CLAMAV_HOST=127.0.0.1
UPLOAD_CLAMAV_PORT=3310
UPLOAD_CLAMAV_TIMEOUT=5
UPLOAD_CLAMAV_FAIL_CLOSED=False

# 安装向导
ENABLE_INSTALLER=False
